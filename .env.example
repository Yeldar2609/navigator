# ----------------------------------------------------------------------------
# Navigator — environment variables
# Copy this file to `.env.local` and fill in real values.
# The app renders without these on Day 1 (auth + DB features degrade gracefully).
# ----------------------------------------------------------------------------

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used by admin/server tasks later.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_LOCALE=ru

# AI counselor — wired in a later phase, NOT used on Day 1.
OPENAI_API_KEY=sk-placeholder-not-used-yet
