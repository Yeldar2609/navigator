# ============================================================================
# Kim Bolam — environment variables (placeholders only; NEVER commit real values)
# Copy to `.env.local` for development. Use Google Secret Manager in production.
# ============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Kim Bolam
NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_SUPPORTED_LOCALES=ru,kk,en
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# --- Firebase (Web App config — Firebase console → Project settings → Your apps) ---
# Client-safe; inlined into the browser bundle at build time.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kim-bolam.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kim-bolam
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kim-bolam.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=887167045950
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# --- Firebase Admin (service account — server only, NEVER expose to browser) ---
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kim-bolam.iam.gserviceaccount.com
# Paste the private key with literal \n escapes, wrapped in quotes.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=kim-bolam.appspot.com
REPORT_BUCKET=kim-bolam.appspot.com

# --- Google Cloud ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=kim-bolam
GOOGLE_CLOUD_PROJECT_NUMBER=887167045950
GOOGLE_CLOUD_REGION=us-central1

# --- AI counselor (Google Conversational Agents / Dialogflow CX) -------------
# Server only. If the agent is not yet created, leave AGENT_ID blank and the
# counselor stays in a production-safe DISABLED state (never faked as real).
ENABLE_AI_COUNSELOR=true
ENABLE_AI_MOCK=false
DIALOGFLOW_CX_PROJECT_ID=kim-bolam
DIALOGFLOW_CX_LOCATION=
DIALOGFLOW_CX_AGENT_ID=
DIALOGFLOW_CX_DEFAULT_LANGUAGE_CODE=ru

# --- Legacy / fallback (Supabase — NOT the production backend) ----------------
# Leave blank to run Firebase-first. Present only for documented fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Dev only ----------------------------------------------------------------
# Production demo preview (e.g. e2e server). Demo mode is fail-closed in prod.
NEXT_PUBLIC_DEMO_MODE=off
